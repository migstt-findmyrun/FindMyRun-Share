{
  "rewrites": [
    { "source": "/run/:id", "destination": "/api/run/:id" },
    { "source": "/club/:id", "destination": "/api/club/:id" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
